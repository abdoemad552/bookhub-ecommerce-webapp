<%-- NEED ANY HELP --%>
<section class="section-block reveal">
    <div class="section-inner">

        <div class="section-head reveal">
            <div>
                <p class="section-eyebrow">We're Here For You</p>
                <h2 class="section-title">Need Any Help?</h2>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

            <%-- Email card --%>
            <div class="feat-card reveal rd1 help-card-link flex justify-between p-4"
               aria-label="Email BookHub support">
                <div class="flex flex-col items-start">
                    <div class="feat-icon mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="text-primary" aria-hidden="true">
                            <path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0z"/>
                            <path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"/>
                        </svg>
                    </div>
                    <div class="flex flex-col gap-1">
                        <h3 class="text-base font-bold text-foreground mb-1">Email Us</h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">
                            Email us, and we'll get back to you within 24 hours.
                        </p>
                        <span class="text-sm font-medium text-accent">support@bookhub.com</span>
                    </div>
                </div>
            </div>

            <%-- Response time card --%>
            <div class="feat-card reveal rd2">
                <div class="feat-icon feat-icon--green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         class="text-primary" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 6v6l4 2"/>
                    </svg>
                </div>
                <div class="flex flex-col gap-0.5 flex-1">
                    <h3 class="text-base font-bold text-foreground mb-1.5">Response Time</h3>
                    <p class="text-muted-foreground text-sm leading-relaxed">
                        Our support team is online and ready to help you any time.
                    </p>
                    <div class="help-online-badge">
                        <span class="help-dot"></span>
                        Online
                    </div>
                </div>
            </div>

            <%-- FAQ card --%>
            <div class="feat-card reveal rd3 help-card-link flex justify-between p-4"
               aria-label="Visit our FAQ page">
                <div class="flex flex-col items-start">
                    <div class="feat-icon feat-icon--amber mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="text-primary" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                            <path d="M12 17h.01"/>
                        </svg>
                    </div>
                    <div class="flex flex-col gap-1">
                        <h3 class="text-base font-bold text-foreground mb-1">FAQ</h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">
                            Browse common questions and find instant answers.
                        </p>
                        <span class="text-sm font-medium text-accent">Visit our FAQ page</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

